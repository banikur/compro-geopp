# Copy this file to .env.local and fill in the values.

# Application URL — used for canonical links and absolute URL references.
APP_URL="http://localhost:3000"

# Resend email API key (get from https://resend.com/api-keys)
RESEND_API_KEY=""

# Email address to receive contact form submissions
CONTACT_TO_EMAIL="pt.geopilarpersada@gmail.com"

# Verified sender email domain in Resend (e.g., onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL="onboarding@resend.dev"

# Admin Basic Auth credentials for /admin routes
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"
